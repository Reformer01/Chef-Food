{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created"
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A user's order",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who placed the order"
        },
        "items": {
          "type": "array",
          "description": "The items in the order",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "image": { "type": "string" }
            },
            "required": ["id", "name", "price", "quantity"]
          }
        },
        "subtotal": {
          "type": "number",
          "description": "The subtotal of the order"
        },
        "deliveryFee": {
          "type": "number",
          "description": "The delivery fee"
        },
        "total": {
          "type": "number",
          "description": "The total amount of the order"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "processing", "completed", "cancelled"],
          "description": "The status of the order"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the order was placed"
        }
      },
      "required": ["userId", "items", "subtotal", "deliveryFee", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "User orders"
    }
  }
}
